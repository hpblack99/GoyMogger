{
  "_comment": "Edit these selectors if the automation fails. Run with debugMode=true in the UI to see the browser live.",
  "urls": {
    "login": "https://www.ffeinc.com/Account/Login",
    "customerPortal": "https://www.ffeinc.com/Customer",
    "rateQuote": "https://www.ffeinc.com/Customer/RateQuote"
  },
  "login": {
    "username": "#UserName",
    "password": "#Password",
    "submit": "input[type='submit'], button[type='submit']",
    "errorMessage": ".validation-summary-errors, .alert-danger, .error-message, [class*='error']"
  },
  "quoteForm": {
    "originZip": "#OriginZip, #ShipperZip, input[name*='Origin'][type='text'], input[name*='Shipper'][type='text']",
    "destZip": "#DestinationZip, #DestZip, #ConsigneeZip, input[name*='Dest'][type='text'], input[name*='Consignee'][type='text']",
    "weight": "#Weight, #TotalWeight, input[name*='Weight']",
    "freightClass": "#FreightClass, #Class, select[name*='Class'], select[name*='Freight']",
    "pieces": "#Pieces, #NumberOfPieces, #PieceCount, input[name*='Piece'], input[name*='Pallet']",
    "submit": "input[type='submit'][value*='Quote'], input[type='submit'][value*='Rate'], input[type='submit'][value*='Get'], button[type='submit']"
  },
  "results": {
    "totalCharge": "[class*='total-charge'], [class*='total-rate'], [class*='net-charge'], td:has-text('Total Charge'), td:has-text('Net Charge'), [id*='TotalCharge'], [id*='TotalRate']",
    "transitDays": "[class*='transit'], [id*='Transit'], td:has-text('Transit'), [class*='days']",
    "quoteNumber": "[class*='quote-number'], [class*='quote-ref'], [id*='QuoteNumber'], [id*='ConfirmationNumber'], td:has-text('Quote #')"
  },
  "rateQuoteLinkText": ["Rate Quote", "Rate", "Get a Quote", "Pricing", "Price"]
}
