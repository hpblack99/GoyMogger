{
  "_comment": "Edit these if automation fails. Run with DEBUG=true to see the browser live. Screenshots are saved to python/screenshots/.",
  "urls": {
    "login": "https://www.ffeinc.com/Account/Login",
    "customer_portal": "https://www.ffeinc.com/Customer",
    "rate_quote": "https://www.ffeinc.com/Customer/RateQuote"
  },
  "login": {
    "username": "#UserName",
    "password": "#Password",
    "submit": "input[type='submit'], button[type='submit']",
    "error": ".validation-summary-errors, .alert-danger, [class*='error']"
  },
  "quote_form": {
    "origin_zip":    "#OriginZip, #ShipperZip, input[name*='Origin'][type='text'], input[name*='Shipper'][type='text']",
    "dest_zip":      "#DestinationZip, #DestZip, #ConsigneeZip, input[name*='Dest'][type='text'], input[name*='Consignee'][type='text']",
    "weight":        "#Weight, #TotalWeight, input[name*='Weight']",
    "freight_class": "#FreightClass, #Class, select[name*='Class'], select[name*='Freight']",
    "pieces":        "#Pieces, #NumberOfPieces, input[name*='Piece'], input[name*='Pallet']",
    "submit":        "input[type='submit'][value*='Quote'], input[type='submit'][value*='Rate'], input[type='submit'][value*='Get'], button[type='submit']"
  },
  "results": {
    "total_charge": "[class*='total-charge'], [class*='net-charge'], [id*='TotalCharge'], [id*='TotalRate']",
    "transit_days": "[class*='transit'], [id*='Transit'], [class*='days']",
    "quote_number": "[class*='quote-number'], [class*='quote-ref'], [id*='QuoteNumber'], [id*='ConfirmationNumber']"
  },
  "rate_quote_link_text": ["Rate Quote", "Rate", "Get a Quote", "Pricing"]
}
