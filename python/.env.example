# Copy to python/.env and fill in your values

# From your Supabase project settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NOT the anon key — needs write access

# Your FFE login credentials (ffeinc.com)
FFE_USERNAME=your@email.com
FFE_PASSWORD=yourpassword

# Set to true to open a visible browser (useful for debugging selectors)
DEBUG=false

# How often the worker checks Supabase for new jobs (seconds)
POLL_INTERVAL=5
